{
  "name": "@ebowwa/claudecodehistory-wasm",
  "version": "0.1.0",
  "description": "High-performance Claude Code history parser compiled to WebAssembly",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "pkg", "src", "types"],
  "scripts": {
    "build": "bun run build:wasm && bun run build:ts",
    "build:wasm": "wasm-pack build --target bundler --out-dir pkg",
    "build:wasm-node": "wasm-pack build --target nodejs --out-dir pkg-node",
    "build:ts": "bun build ./src/index.ts --outdir ./dist --target=bun && tsc --emitDeclarationOnly --declaration --outDir ./dist",
    "test": "bun test",
    "clean": "rm -rf dist pkg pkg-node target"
  },
  "keywords": ["claude-code", "history", "parser", "wasm", "webassembly", "rust", "performance"],
  "author": "ebowwa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebowwa/codespaces",
    "directory": "packages/src/claudecodehistory-wasm"
  },
  "engines": { "bun": ">=1.0.0" },
  "dependencies": {},
  "devDependencies": {
    "bun-types": "^1.3.9",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
